# ============================================================
#  network.env — Cross-machine ROS 2 DDS peer configuration
#  Edit these two lines with your actual IP addresses, then
#  re-run both launch scripts. Run `hostname -I` on each
#  machine to find its IP.
# ============================================================

# IP of the desktop/workstation running the simulation
WORKSTATION_IP=192.168.1.100

# IP of the Raspberry Pi 5 running the robot
PI_IP=192.168.1.101
