# ============================================================
#  network.env — Cross-machine ROS 2 DDS peer configuration
#
#  NOTE: This file is kept for backward compatibility.
#        New deployments should use deployment.env instead:
#          python deploy.py
#
#  Edit these lines with your actual IP addresses, then
#  re-run the launch scripts. Run `hostname -I` on each
#  machine to find its IP.
# ============================================================

# IP of the VLA inference workstation (PC1, RTX 5060 Ti / 5090)
VLA_PC_IP=192.168.1.100

# Backward-compat alias — launch scripts accept both names
WORKSTATION_IP=192.168.1.100

# IP of the Raspberry Pi 5 running the robot
PI_IP=192.168.1.101

# IP of the simulation workstation (PC2 — Isaac Sim / Gazebo)
SIM_PC_IP=192.168.1.102
