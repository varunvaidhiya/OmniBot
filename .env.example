# ============================================================
# OmniBot environment variables — copy to .env and edit
# ============================================================

# ── Deployment mode ──────────────────────────────────────────
# Run `python deploy.py` to configure this interactively.
# Values: single | multi
#   single — all nodes on one workstation (RTX 5090 etc.)
#   multi  — three machines: Pi + PC1 (VLA) + PC2 (Sim)
DEPLOY_MODE=single

# ── Network ─────────────────────────────────────────────────
# Raspberry Pi 5 running the physical robot
ROBOT_IP=192.168.1.101
PI_IP=192.168.1.101

# PC1 — VLA inference workstation (RTX 5060 Ti / 5090)
VLA_PC_IP=192.168.1.100
WORKSTATION_IP=192.168.1.100    # backward-compat alias

# PC2 — Simulation workstation (Isaac Sim / Gazebo)
SIM_PC_IP=192.168.1.102

ROS_DOMAIN_ID=30

# ── VLA Inference Server ─────────────────────────────────────
VLA_MODEL_CLASS=vla_serve.models.openvla.OpenVLAModel
VLA_MODEL_PATH=openvla/openvla-7b
VLA_LOAD_4BIT=0
VLA_AUTO_LOAD=0
VLA_PORT=8000

# API key for the /predict endpoint (generate with: openssl rand -hex 32)
# Leave empty to disable authentication (not recommended for production)
VLA_API_KEY=

# Rate limit for /predict: requests per second per API key
VLA_RATE_LIMIT=10

# ── ROS 2 ────────────────────────────────────────────────────
ROS_DISTRO=jazzy

# ── Hardware ports (override in container or systemd unit) ───
YAHBOOM_PORT=/dev/ttyUSB0
ARM_FOLLOWER_PORT=/dev/ttyACM0
ARM_LEADER_PORT=/dev/ttyACM1
