<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>yahboom_ros2</name>
  <version>1.0.0</version>
  <description>
    ROS 2 driver for the Yahboom ROS Robot Expansion Board (Rosmaster series).
    Includes the reverse-engineered serial protocol encoder/decoder, odometry
    integration, IMU publishing, and velocity-ramped holonomic motion commands.
    Compatible with any robot using the Yahboom board (X3, R2, etc.).
  </description>

  <maintainer email="varunvaidhiya@example.com">Varun Vaidhiya</maintainer>
  <license>Apache-2.0</license>

  <url type="website">https://github.com/varunvaidhiya/Mecanum-Wheel-Robot</url>
  <url type="repository">https://github.com/varunvaidhiya/Mecanum-Wheel-Robot</url>
  <url type="bugtracker">https://github.com/varunvaidhiya/Mecanum-Wheel-Robot/issues</url>

  <buildtool_depend>ament_python</buildtool_depend>

  <depend>rclpy</depend>
  <depend>geometry_msgs</depend>
  <depend>nav_msgs</depend>
  <depend>sensor_msgs</depend>
  <depend>std_msgs</depend>
  <depend>tf2_ros</depend>
  <depend>tf_transformations</depend>

  <exec_depend>python3-serial</exec_depend>
  <exec_depend>python3-numpy</exec_depend>

  <export>
    <build_type>ament_python</build_type>
  </export>
</package>
