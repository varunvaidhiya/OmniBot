<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>mecanum_drive_ros2</name>
  <version>1.0.0</version>
  <description>
    Generic mecanum wheel kinematics library for ROS 2.
    Provides forward/inverse kinematics and pose integration as both a
    header-only C++17 library and a pure-Python module — no hardware dependency.
    Works with any mecanum robot regardless of motor board.
  </description>

  <maintainer email="varunvaidhiya@example.com">Varun Vaidhiya</maintainer>
  <license>Apache-2.0</license>

  <url type="website">https://github.com/varunvaidhiya/Mecanum-Wheel-Robot</url>

  <buildtool_depend>ament_cmake</buildtool_depend>
  <buildtool_depend>ament_cmake_python</buildtool_depend>

  <depend>rclcpp</depend>
  <depend>rclpy</depend>
  <depend>geometry_msgs</depend>
  <depend>nav_msgs</depend>
  <depend>tf2_ros</depend>

  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>
