<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050510">

    <!-- SceneView: Filament-powered 3D scene -->
    <io.github.sceneview.SceneView
        android:id="@+id/scene_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- No-model banner (shown until robot.glb is placed in assets/) -->
    <LinearLayout
        android:id="@+id/layout_no_model"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#CC1A1A2E"
        android:padding="16dp"
        android:layout_gravity="center">

        <ImageView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_3d_map"
            android:tint="#64B5F6"
            android:contentDescription="3D model icon"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3D Robot Model Not Found"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Export your URDF first, then copy the output to:\nandroid_app/app/src/main/assets/robot.glb"
            android:textColor="#B0BEC5"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="python tools/urdf_to_glb.py"
            android:textColor="#64B5F6"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:background="#1A1A3E"
            android:padding="8dp"
            android:layout_marginTop="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Robot pose and joint states are still shown below"
            android:textColor="#80FFFFFF"
            android:textSize="11sp"
            android:layout_marginTop="10dp" />

    </LinearLayout>

    <!-- Top-right: connection + model status -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#AA000000"
        android:padding="6dp"
        android:gravity="center_vertical"
        android:layout_gravity="top|end"
        android:layout_margin="12dp">

        <View
            android:id="@+id/viewer_status_dot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/shape_circle_red"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/text_model_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No model"
            android:textColor="#FFFFFF"
            android:textSize="11sp" />

    </LinearLayout>

    <!-- Bottom info panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#CC000000"
        android:padding="12dp"
        android:layout_gravity="bottom">

        <!-- Pose row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="POSE"
                android:textColor="#64B5F6"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginEnd="12dp" />

            <TextView
                android:id="@+id/text_viewer_x"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="X: 0.00"
                android:textColor="#FFFFFF"
                android:fontFamily="monospace"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/text_viewer_y"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Y: 0.00"
                android:textColor="#FFFFFF"
                android:fontFamily="monospace"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/text_viewer_yaw"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="θ: 0°"
                android:textColor="#FFFFFF"
                android:fontFamily="monospace"
                android:textSize="11sp" />

        </LinearLayout>

        <!-- Joint angles row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ARM"
                android:textColor="#64B5F6"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginEnd="12dp" />

            <TextView
                android:id="@+id/text_joint_values"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0° 0° 0° 0° 0° 0°"
                android:textColor="#FFFFFF"
                android:fontFamily="monospace"
                android:textSize="11sp" />

        </LinearLayout>

        <!-- Hint row -->
        <TextView
            android:id="@+id/text_tap_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap floor plane to send Nav2 goal · Pinch to orbit"
            android:textColor="#60FFFFFF"
            android:textSize="10sp"
            android:layout_marginTop="6dp" />

    </LinearLayout>

</FrameLayout>
