<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Connection Status Bar -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_connection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="14dp"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/status_indicator"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="@drawable/shape_circle_red" />

                <TextView
                    android:id="@+id/text_connection_status"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:text="Disconnected"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/text_ip_address"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="IP: --"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Camera Feed Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_camera"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardBackgroundColor="#000000"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- MJPEG stream (16:9 ratio) -->
                <com.varunvaidhiya.robotcontrol.ui.views.MjpegView
                    android:id="@+id/mjpeg_view"
                    android:layout_width="match_parent"
                    android:layout_height="210dp" />

                <!-- BEV overlay (small SLAM mini-map in top-right corner) -->
                <FrameLayout
                    android:id="@+id/bev_overlay_container"
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="8dp"
                    android:background="#CC000000"
                    android:visibility="gone">

                    <com.varunvaidhiya.robotcontrol.ui.views.SlamMapView
                        android:id="@+id/bev_slam_view"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BEV"
                        android:textColor="#FFFFFF"
                        android:textSize="9sp"
                        android:layout_gravity="bottom|start"
                        android:paddingStart="4dp"
                        android:paddingBottom="2dp" />

                </FrameLayout>

                <!-- "LIVE" indicator top-left -->
                <TextView
                    android:id="@+id/text_live_indicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="● LIVE"
                    android:textColor="#FF4444"
                    android:textSize="11sp"
                    android:background="#CC000000"
                    android:padding="4dp"
                    android:layout_gravity="top|start"
                    android:layout_margin="8dp" />

                <!-- REC badge (shown while recording) -->
                <TextView
                    android:id="@+id/text_rec_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏺ REC"
                    android:textColor="#FF4444"
                    android:textSize="11sp"
                    android:background="#CC000000"
                    android:padding="4dp"
                    android:layout_gravity="top|start"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="36dp"
                    android:visibility="gone" />

                <!-- Camera overlay controls (bottom row) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="end"
                    android:layout_gravity="bottom"
                    android:background="#88000000"
                    android:padding="4dp">

                    <!-- BEV toggle -->
                    <ImageButton
                        android:id="@+id/btn_bev_toggle"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_bev"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Toggle BEV overlay"
                        android:tint="#FFFFFF"
                        android:layout_marginEnd="8dp" />

                    <!-- Fullscreen button -->
                    <ImageButton
                        android:id="@+id/btn_fullscreen"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_fullscreen"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Fullscreen camera"
                        android:tint="#FFFFFF"
                        android:layout_marginEnd="4dp" />

                </LinearLayout>

            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Velocity Chart Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Velocity"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp" />

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/chart_velocity"
                    android:layout_width="match_parent"
                    android:layout_height="130dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Odometry Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Odometry"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/text_odom_x"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="X: 0.00 m"
                        android:textColor="@color/text_primary"
                        android:fontFamily="monospace"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/text_odom_y"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Y: 0.00 m"
                        android:textColor="@color/text_primary"
                        android:fontFamily="monospace"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/text_odom_yaw"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="θ: 0.0°"
                        android:textColor="@color/text_primary"
                        android:fontFamily="monospace"
                        android:textSize="13sp" />

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
