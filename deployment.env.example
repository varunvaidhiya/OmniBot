# ============================================================
# deployment.env.example — OmniBot deployment configuration
# ============================================================
# Copy to deployment.env (or run `python deploy.py` to generate it).
#
# DEPLOY_MODE controls how all launch scripts configure ROS 2 DDS peers:
#
#   single — Everything runs on one workstation (e.g. RTX 5090).
#            ROS_STATIC_PEERS is left unset; DDS uses localhost by default.
#            Use: ./launch_simulation.sh  or  ./launch_mobile_manipulation.sh
#
#   multi  — Three-machine distributed setup:
#              Pi   — robot driver, Nav2, SLAM, ROSBridge (:9090)
#              PC1  — VLA inference (vla_node, smolvla_node)
#              PC2  — Isaac Sim / Gazebo + bev_stitcher_node
#            Use:
#              Pi:  ./launch_rosbridge.sh
#              PC1: ros2 launch omnibot_vla vla_desktop.launch.py
#              PC2: ./launch_sim_pc.sh
#
# Run `python deploy.py` for an interactive configurator.
# ============================================================

# ── Mode ────────────────────────────────────────────────────
# Values: single | multi
DEPLOY_MODE=single

# ── Machine IPs (used only in multi mode) ───────────────────
# PC1: VLA inference workstation (RTX 5060 Ti or similar)
VLA_PC_IP=192.168.1.100

# Raspberry Pi 5 running the physical robot
PI_IP=192.168.1.101

# PC2: Simulation workstation (Isaac Sim / Gazebo)
SIM_PC_IP=192.168.1.102

# ── ROS 2 ────────────────────────────────────────────────────
# Must match on ALL machines in the same session.
ROS_DOMAIN_ID=30

# Backward-compat alias — kept so older scripts that reference
# WORKSTATION_IP continue to work. Points to VLA_PC_IP.
WORKSTATION_IP=192.168.1.100
